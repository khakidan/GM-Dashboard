# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_CLIENT_ID: Required for Google Sheets API integration
# Users must configure this via the Settings > Secrets panel using the Client ID from Google Cloud Console
VITE_GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"

# VITE_GOOGLE_CLIENT_SECRET: Optional but recommended for persistent (offline) authentication.
# Without this, tokens will expire in 1 hour. With it, a refresh token can be used indefinitely.
VITE_GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"

# VITE_SPREADSHEET_ID: Optional default ID for the database
VITE_SPREADSHEET_ID="YOUR_SPREADSHEET_ID"
